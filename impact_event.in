clear
units           metal
boundary        p p p
atom_style      atomic

read_data       baseline.data

pair_style      hybrid eam/fs lj/cut 6.0
pair_coeff      * * eam/fs AlFe_mm.eam.fs Fe Al Fe NULL NULL
pair_coeff      4 4 lj/cut 5.0 2.3
pair_coeff      5 5 lj/cut 5.0 2.8
pair_coeff      4 5 lj/cut 5.0 2.5
pair_coeff      1 4 lj/cut 1.0 2.0
# (Insert remaining lj/cut coefficients here)

# PLASMA GENERATION
velocity        all create 17000.0 88888
fix             1 all nve
thermo          100
run             1000
write_data      impact_state.data
